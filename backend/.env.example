# zzrpg backend configuration. Copy to .env for local dev, or set these as
# real environment variables in production. Defaults live in pkg/config.

# ── Core ──────────────────────────────────────────────────────────────────────
# "production" enforces the security checks below; anything else is development.
ENV=production
PORT=8080

# ── Secrets & data stores (REQUIRED in production) ────────────────────────────
# JWT_SECRET must be >= 32 chars in production; generate e.g. `openssl rand -hex 32`.
JWT_SECRET=change-me-to-a-32+-char-random-secret
DATABASE_URL=postgres://user:pass@postgres:5432/zzrpg?sslmode=require
REDIS_URL=redis://redis:6379/0

# ── Cross-origin (browser clients) ────────────────────────────────────────────
# Comma-separated allowlist for CORS and WebSocket upgrades. Use exact origins.
# "*" allows any origin. Empty in production denies all cross-origin requests.
ALLOWED_ORIGINS=https://play.example.com,https://admin.example.com

# ── Native stat engine ────────────────────────────────────────────────────────
# Absolute path to the Rust libzzstat_ffi.so. The Docker image sets this for you.
ZZSTAT_LIB_PATH=/app/libzzstat_ffi.so

# ── HTTP hardening (optional; sensible defaults) ──────────────────────────────
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40
MAX_BODY_BYTES=1048576
OUTBOX_RETENTION=24h

# ── Idle progression (optional) ───────────────────────────────────────────────
# How often online characters accrue real-time idle progress and get IDLE_TICK.
IDLE_TICK_INTERVAL=15s

# ── Token lifetimes (optional) ────────────────────────────────────────────────
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
